# Copy to `.env.local` and fill in. Never commit `.env.local`.
# Server-side (API routes): see each route for GEMINI_*, DOUBAO_*, GROK_*, etc.

# --- 豆包语音：大模型录音文件极速版（/api/asr 默认）---
# 文档: https://www.volcengine.com/docs/6561/1631584?lang=zh
# 新版控制台：仅填 App Key
DOUBAO_SPEECH_API_KEY=
# 与控制台一致的 uid，默认可与 API Key 相同
# DOUBAO_SPEECH_UID=
# 可选，覆盖默认接口地址
# DOUBAO_SPEECH_FLASH_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash
# 旧版控制台（需 App Id + Access Token）时取消注释并填写：
# DOUBAO_SPEECH_LEGACY_APP_KEY=
# DOUBAO_SPEECH_LEGACY_ACCESS_KEY=

# --- OpenAI 兼容文本 API（润色/解析/补全/生图 prompt）：服务端兜底 ---
# 未配置 NEXT_PUBLIC_LLM_* 时，按请求里的 x-api-url 选密钥：openclaudecode ≠ 4Router ≠ 豆包
# openclaudecode（同一域名，多 Key / 多分组时拆开写）
OPENCLAUDECODE_API_URL=https://www.openclaudecode.cn/v1
OPENCLAUDECODE_API_KEY_GPT=
OPENCLAUDECODE_API_KEY_CLAUDE=
# 若两端共用一把 Key，可只填：
# OPENCLAUDECODE_API_KEY=

# 4Router 等（与 openclaudecode 无关，勿混用）
GEMINI_API_URL=
GEMINI_API_KEY=
GEMINI_MODEL=

# 豆包 Ark（与上两者无关；生图可走 DOUBAO_* 或下方 GROK_*）
# DOUBAO_API_URL=
# DOUBAO_API_KEY=
# DOUBAO_IMAGE_MODEL=

# --- Grok Imagine：场景生图（/api/render phase=images）与梦境视频（/api/video）---
# 需网关提供与 xAI 一致的 REST 路径，见：
# https://docs.x.ai/developers/model-capabilities/images/generation
# https://docs.x.ai/developers/model-capabilities/video/generation
GROK_API_URL=https://www.openclaudecode.cn/v1
GROK_API_KEY=
GROK_IMAGE_MODEL=grok-imagine-video-lite
GROK_VIDEO_MODEL=grok-imagine-video
# 若中转站文档要求其它路径（默认 videos/generations）
# GROK_VIDEO_GENERATIONS_PATH=videos/generations
# GROK_VIDEO_POLL_INTERVAL_MS=5000
# GROK_VIDEO_POLL_TIMEOUT_MS=900000
# 生图：场景之间间隔（毫秒），减轻「No available accounts」类限流
# GROK_IMAGE_SCENE_GAP_MS=2800
# GROK_IMAGE_RATE_LIMIT_RETRIES=6
# GROK_IMAGE_RATE_LIMIT_BASE_MS=2200

# --- Browser / model picker (`src/app/page.tsx`, NEXT_PUBLIC_* is exposed to the client) ---
NEXT_PUBLIC_LLM_OPENCLAUDECODE_URL=https://www.openclaudecode.cn/v1
NEXT_PUBLIC_LLM_OPENCLAUDECODE_KEY_GPT=
NEXT_PUBLIC_LLM_OPENCLAUDECODE_KEY_CLAUDE=

NEXT_PUBLIC_LLM_4ROUTER_URL=https://4Router.net/v1
NEXT_PUBLIC_LLM_4ROUTER_KEY=

NEXT_PUBLIC_LLM_DOUBAO_URL=https://ark.cn-beijing.volces.com/api/v3
NEXT_PUBLIC_LLM_DOUBAO_KEY=
